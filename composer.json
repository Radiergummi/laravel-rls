{
    "name": "radiergummi/laravel-rls",
    "description": "PostgreSQL Row-Level Security for Laravel",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "tpetry/laravel-postgresql-enhanced": "^3.7",
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.2",
        "larastan/larastan": "^3.10",
        "ext-pdo": "*",
        "laravel/octane": "^2.17",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-mockery": "^2.0"
    },
    "scripts": {
        "bench": "php bench/run.php",
        "test": "vendor/bin/phpunit --configuration=phpunit.xml",
        "lint": "phpstan analyse --memory-limit=1G --configuration=phpstan.neon",
        "format": "pint --parallel --max-processes=auto --cache-file=vendor/.cache/pint.json",
        "fmt": "@format"
    },
    "autoload": {
        "psr-4": { "Radiergummi\\LaravelRls\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": {
            "Radiergummi\\LaravelRls\\Tests\\": "tests/",
            "Radiergummi\\LaravelRls\\Tests\\Fixtures\\Database\\Factories\\": "tests/Fixtures/database/factories/",
            "Radiergummi\\LaravelRls\\Bench\\": "bench/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Radiergummi\\LaravelRls\\RlsServiceProvider"]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
